# LingXi Service Configuration

# LLM Configuration
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Session Configuration
SESSION_TTL=3600
MAX_HISTORY_LENGTH=20

# App Configuration
APP_NAME=lingxi-service
APP_ENV=development
LOG_LEVEL=INFO
