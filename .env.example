# LingXi Service Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=lingxi-service
APP_ENV=development
LOG_LEVEL=INFO
PORT=8002

# LLM Configuration
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Session Configuration
SESSION_TTL=3600
MAX_HISTORY_LENGTH=20

# Database (MySQL - optional, leave empty to use mock data)
DATABASE_URL=mysql+aiomysql://lingxi:lingxi_password@localhost:3306/lingxi
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# MySQL Docker Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=lingxi
MYSQL_USER=lingxi
MYSQL_PASSWORD=lingxi_password

# Vector Search / RAG
VECTOR_BACKEND=qdrant
VECTOR_PERSIST_DIRECTORY=./data/rag_vectors
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=not-set
QDRANT_COLLECTION=faq_knowledge
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=not-set
EMBEDDING_LOCAL_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_ENABLED=true
EMBEDDING_CACHE_TTL_SECONDS=2592000
KNOWLEDGE_TOP_K=3
RAG_SCORE_THRESHOLD=0.2
HYBRID_RAG_WEIGHT=0.7
HYBRID_KEYWORD_WEIGHT=0.3

# Security (change in production!)
API_KEY=your-secure-api-key
AUTH_ENABLED=true
CORS_ORIGINS=["*"]
RATE_LIMIT=100/minute

# Cache Configuration
CACHE_MAX_SIZE=1000
CACHE_TTL_SECONDS=3600

# Input Validation
MAX_MESSAGE_LENGTH=10000
MAX_REQUEST_SIZE=1048576
