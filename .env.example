# LingXi Service Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=lingxi-service
APP_ENV=development
LOG_LEVEL=INFO
PORT=8002

# LLM Configuration
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Session Configuration
SESSION_TTL=3600
MAX_HISTORY_LENGTH=20

# Database (MySQL - optional, leave empty to use mock data)
DATABASE_URL=mysql+pymysql://lingxi:lingxi_password@localhost:3306/lingxi

# MySQL Docker Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=lingxi
MYSQL_USER=lingxi
MYSQL_PASSWORD=lingxi_password

# Security (change in production!)
API_KEY=your-secure-api-key
AUTH_ENABLED=false
CORS_ORIGINS=["*"]
RATE_LIMIT=100/minute

# Cache Configuration
CACHE_MAX_SIZE=1000
CACHE_TTL_SECONDS=3600

# Input Validation
MAX_MESSAGE_LENGTH=10000
MAX_REQUEST_SIZE=1048576
